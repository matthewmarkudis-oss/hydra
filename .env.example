# HydraCorp API Keys
# Copy this file to .env and fill in your keys
# DO NOT commit the .env file to version control

# NewsAPI — https://newsapi.org/register (free tier: 100 req/day)
NEWSAPI_KEY=your_newsapi_key_here

# Finnhub — https://finnhub.io/register (free tier: 60 req/min)
FINNHUB_API_KEY=your_finnhub_key_here

# Anthropic — https://console.anthropic.com (for Claude Haiku LLM analysis)
# Used by: geopolitics_expert, contrarian, hedge_fund_director, ceo_interface
ANTHROPIC_API_KEY=your_anthropic_key_here
